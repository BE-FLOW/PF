# Optional for basic checks: without a key, PetFlow uses built-in safety rules.
# Required for AI veterinary summaries. Keep every OPENAI_* value server-only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
# Monthly AI summaries included for every signed-in user. Defaults to 5.
AI_REPORT_MONTHLY_LIMIT=5
OPENAI_INPUT_COST_USD_PER_1M_TOKENS=0.75
OPENAI_OUTPUT_COST_USD_PER_1M_TOKENS=4.50

# Server-only Supabase credentials. Never prefix these with NEXT_PUBLIC_.
SUPABASE_URL=https://your-test-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Browser-safe Supabase credentials used for Auth and owner-only pet profiles.
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional label shown in health checks when Vercel commit metadata is unavailable.
NEXT_PUBLIC_APP_VERSION=local
