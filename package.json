{
  "name": "petflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "db:start": "npx supabase start",
    "db:reset": "npx supabase db reset",
    "db:test": "npx supabase test db",
    "db:cleanup:dummy": "node scripts/cleanup-dummy-data.mjs",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "verify:all": "npm run lint && npm test && npm run build && npm --prefix apps/mobile run verify",
    "release:preflight:android": "npm --prefix apps/mobile run release:preflight:android",
    "release:preflight:ios": "npm --prefix apps/mobile run release:preflight:ios"
  },
  "dependencies": {
    "@fontsource/pretendard": "^5.2.5",
    "@supabase/supabase-js": "^2.108.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
